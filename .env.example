# Env keys consumed by the foodhealthco-ndo-ops plugin's ndo-run skill.
# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is gitignored.

# --- NDO Postgres connection strings ---
# DEV: typically a smaller throwaway db for safe rehearsal
NDO_DEV_DATABASE_URL=postgresql://user:pass@host:port/dbname
# PROD: the live NDO database
NDO_PROD_DATABASE_URL=postgresql://user:pass@host:port/dbname

# --- DO Spaces (object storage for CSV uploads + tagging configs) ---
# Get a Spaces Access Key from cloud.digitalocean.com → API → Spaces Keys.
# Key must have read+write on the `btw-nutrition` bucket.
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_REGION=nyc3
# Optional: DO_SPACES_ENDPOINT is auto-derived from region for the generic
# regional endpoint. Only set if you need a non-default endpoint.

# --- FHS scoring API (DigitalOcean waterfall host — what NDO main scores against) ---
# NDO main sends an `items` schema this host speaks. Do NOT point this at the GCP
# fhs-api.foodhealth.co Laravel API — that expects a `products` schema NDO does not
# send, so scoring would fail (422). GCP scoring migration is future work (ENG-874/965).
FHS_API_URL=https://waterfall-fhs-app-p5un2.ondigitalocean.app
FHS_API_TOKEN=
# Publish only (send_to_clients → FHSAPIClient POST /api/v1/score/result):
FHSAPI_BASE_URL=https://fhs-api.bitewell.com/api/v1
FHSAPI_API_TOKEN=

# --- Tagging config (must match what's set in DO App Platform for NDO prod) ---
# The DO Spaces key under btw-nutrition/ that holds the production tagging
# rules. Check the NDO production App Platform env vars for the current value.
DEFAULT_TAGGING_FILE=t2t_v4.csv

# --- Optional: BentoML category prediction (used by backfill_categories) ---
CATEGORY_ENDPOINT_URL=
CATEGORY_ENDPOINT_TOKEN=

# --- Optional: HeroDB (--db platform routing; not yet functional — ENG-897) ---
FHS_HUB_DATABASE_URL=

# --- Optional: OpenSearch (consumed by --with-reindex chain) ---
# Required only when running `backfill_fhs --with-reindex` (or
# `backfill_fhs_and_refresh_view_command --with-reindex`) against prod so the
# runner can chain `index_scored_view_command` to push scored products into
# consumer search. The chain auto-skips when DO_OPENSEARCH_URL is unset (and
# always skips on --target dev — dev OpenSearch is not wired the same way).
# Pull these from the NDO production App Platform env vars.
DO_OPENSEARCH_URL=
DO_OPENSEARCH_PORT=25060
DO_OPENSEARCH_USERNAME=
DO_OPENSEARCH_PASSWORD=
DO_OPENSEARCH_USE_SSL=True
